        extern void vector_imm_merge(unsigned<VLEN> V[32], unsigned<XLEN> vl, unsigned<XLEN> vstart, unsigned<XLEN> vtype, unsigned<1> vm, unsigned<5> vd, unsigned<5> vs2, unsigned<ELEN> imm, unsigned<3> sew);
        extern void fp_vector_unary_w(unsigned<VLEN> V[32], unsigned<5> unary_op, unsigned<XLEN> vl, unsigned<XLEN> vstart, unsigned<XLEN> vtype, unsigned<1> vm, unsigned<5> vd, unsigned<5> vs2, unsigned<3> rm, unsigned<3> sew);
        extern void fp_vector_unary_n(unsigned<VLEN> V[32], unsigned<5> unary_op, unsigned<XLEN> vl, unsigned<XLEN> vstart, unsigned<XLEN> vtype, unsigned<1> vm, unsigned<5> vd, unsigned<5> vs2, unsigned<3> rm, unsigned<3> sew);

        unsigned<1> illegal_fp_variable_width(unsigned<5> vd, unsigned<1>vm, unsigned<8> SEW, unsigned<3> rm,  unsigned<7> SEW_new, signed<4> LMUL_pow_new) {
            return !(valid_vtype()) || !(valid_rd_mask(vd, vm)) || !(valid_fp_op(SEW, rm)) || !(valid_eew_emul(SEW_new, LMUL_pow_new));
        }
        unsigned<1> illegal_fp_vd_masked(unsigned<5> vd, unsigned<8> SEW, unsigned<3> rm) {
            return !(valid_vtype()) || vd == 5'b00000 || !(valid_fp_op(SEW, rm));
        }
    }
    instructions{
        // 31.13.2. Vector Single-Width Floating-Point Add/Subtract Instructions
        VFADD__VF {
            encoding: 6'b000000 :: vm[0:0] :: vs2[4:0] :: rs1[4:0] :: 3'b101 :: vd[4:0] :: 7'b1010111;
            assembly: "{vname(vd)}, {vname(vs2)}, {fname(rs1)}, {vm}";
            behavior: {
                unsigned<8> SEW = (unsigned<8>)(8'sb1 << (get_sew_pow())) & ~8'b1;
                unsigned<3> rm = FCSR[7:5];
                if(illegal_fp_normal(vd, vm, SEW, rm)) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                else {
                    if(vl > vstart){
                        fp_vector_imm_op(V, 6'b000000, 3'b101, vl, vstart, vtype, vm, vd, vs2, (unsigned<ELEN>)F[rs1], rm, sew());
                        unsigned<32> flags = fget_flags();
                        FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
                    }
                    vstart = 0;
                }
            }
        }
