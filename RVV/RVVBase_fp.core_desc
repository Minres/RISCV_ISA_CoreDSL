            encoding: 6'b010010 :: vm[0:0] :: vs2[4:0] :: 5'b10101 :: 3'b001 :: vd[4:0] :: 7'b1010111;
            assembly: "{vname(vd)}, {vname(vs2)}, {vm}";
            behavior: {
                unsigned<8> SEW = (unsigned<8>)(8'sb1 << (get_sew_pow())) & ~8'b1;
                signed<3> LMUL_pow = get_lmul_pow();
                unsigned<7> SEW_widen = (unsigned<6>)(SEW * 2);
                signed<4> LMUL_pow_widen = LMUL_pow + 1;
                unsigned<3> rm = FCSR[7:5];
                if(illegal_fp_variable_width(vd, vm, SEW, rm, SEW_widen, LMUL_pow_widen) || !valid_reg_overlap(vs2, vd, LMUL_pow_widen, LMUL_pow)) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                else {
                    if(vl > vstart)
                        fp_vector_unary_n(V, 5'b10101, vl, vstart, vtype, vm, vd, vs2, 3'b110, sew());
                    vstart = 0;
                }
            }
        }
    }
}