        /*
        funct beginning with 00, namely:
        VV_VADD          <-> 0b000000,
        VV_VSUB          <-> 0b000010,
        VV_VMINU         <-> 0b000100,
        VV_VMIN          <-> 0b000101,
        VV_VMAXU         <-> 0b000110,
        VV_VMAX          <-> 0b000111,
        VV_VAND          <-> 0b001001,
        VV_VOR           <-> 0b001010,
        VV_VXOR          <-> 0b001011,

        These should be considered to be excluded as they need a copy of the vs2 register to work on
        VV_VRGATHER      <-> 0b001100, also needs  if (vs1 == vd | vs2 == vd) raise(0,2)
        This one even sets different EEW for source and destination
        VV_VRGATHEREI16  <-> 0b001110, also needs  if (vs1 == vd | vs2 == vd) raise(0,2)

        can be extended to take on the following:
        VV_VSADDU        <-> 0b100000,
        VV_VSADD         <-> 0b100001,
        VV_VSSUBU        <-> 0b100010,
        VV_VSSUB         <-> 0b100011,
        VV_VSLL          <-> 0b100101,
        VV_VSMUL         <-> 0b100111,
        VV_VSRL          <-> 0b101000,
        VV_VSRA          <-> 0b101001,
        VV_VSSRL         <-> 0b101010,
        VV_VSSRA         <-> 0b101011
        */
        VVTYPE {
            encoding: funct6[5:0] :: vm[0:0] :: vs2[4:0] :: vs1[4:0] :: 3'b000 :: vd[4:0] :: 7'b1010111;
            assembly: "{vname(vd)}, {vname(vs2)}, {vname(vs1)}, {vm}";
            behavior: {
                if(illegal_normal(vd, vm)) raise(0,2);
                else{
                    vector_vector_op(V, funct6, vl, vstart, vtype, vm, vd, vs2, vs1, sew());
                }
            }
        }
    }
