import "RVVBase.core_desc"

InstructionSet RVVBase_mem extends RVVBase {
    functions {
        unsigned<4> convert_width(unsigned<3> width){
            switch(width){
                case(3'b000): return 1;
                case(3'b101): return 2;
                case(3'b110): return 4;
                case(3'b111): return 8;
            }
            return 0;
        }
        unsigned<1> illegal_load(unsigned<5> vd, unsigned<1> vm, unsigned<4> nf, unsigned<7> EEW, signed<3> EMUL_pow){
            return !valid_vtype() || ! valid_rd_mask(vd, vm) || !valid_eew_emul(EEW, EMUL_pow) || !valid_segment(nf, EMUL_pow);
        }
        unsigned<1> illegal_store(unsigned<4> nf, unsigned<7> EEW, signed<3> EMUL_pow) {
            return !valid_vtype() || !valid_eew_emul(EEW, EMUL_pow) || !valid_segment(nf, EMUL_pow);
        }
        unsigned<1> illegal_indexed_load(unsigned<5> vd, unsigned<1> vm, unsigned<4> nf, unsigned<7> EEW_index, signed<3> EMUL_pow_index, signed<3> EMUL_pow_data) {
            return !valid_vtype() || !valid_rd_mask(vd, vm) || !valid_eew_emul(EEW_index, EMUL_pow_index) || !valid_segment(nf, EMUL_pow_data);
        }
        unsigned<1> illegal_indexed_store(unsigned<4> nf, unsigned<7> EEW_index, signed<3> EMUL_pow_index, signed<3> EMUL_pow_data) {
            return !valid_vtype() || !valid_eew_emul(EEW_index, EMUL_pow_index) || !valid_segment(nf, EMUL_pow_data);
        }
        extern void lower();
        extern unsigned<64> vlseg(unsigned<VLEN> V[32], unsigned<XLEN> vl, unsigned<XLEN> vstart, unsigned<XLEN> vtype, unsigned<1> vm,  unsigned<5> vd, unsigned<XLEN> rs1_val, unsigned<3> width, unsigned<4> nf) [[uses_mem]];
        extern unsigned<64> vsseg(unsigned<VLEN> V[32], unsigned<XLEN> vl, unsigned<XLEN> vstart, unsigned<XLEN> vtype, unsigned<1> vm,  unsigned<5> vd, unsigned<XLEN> rs1_val, unsigned<3> width, unsigned<4> nf) [[uses_mem]];
        extern unsigned<64> vlsseg(unsigned<VLEN> V[32], unsigned<XLEN> vl, unsigned<XLEN> vstart, unsigned<XLEN> vtype, unsigned<1> vm,  unsigned<5> vd, unsigned<XLEN> rs1_val, unsigned<3> width, unsigned<4> nf, signed<XLEN> rs2_val) [[uses_mem]];
        extern unsigned<64> vssseg(unsigned<VLEN> V[32], unsigned<XLEN> vl, unsigned<XLEN> vstart, unsigned<XLEN> vtype, unsigned<1> vm,  unsigned<5> vd, unsigned<XLEN> rs1_val, unsigned<3> width, unsigned<4> nf, signed<XLEN> rs2_val) [[uses_mem]];
        extern unsigned<64> vlxseg(unsigned<VLEN> V[32], unsigned<XLEN> vl, unsigned<XLEN> vstart, unsigned<XLEN> vtype, unsigned<1> vm, unsigned<5> vd, unsigned<XLEN> rs1_val, unsigned<5> vs2, unsigned<4> nf, unsigned<4> index_byte_size, unsigned<3> data_byte_size, unsigned<1> ordered) [[uses_mem]];
        extern unsigned<64> vsxseg(unsigned<VLEN> V[32], unsigned<XLEN> vl, unsigned<XLEN> vstart, unsigned<XLEN> vtype, unsigned<1> vm, unsigned<5> vs3, unsigned<XLEN> rs1_val, unsigned<5> vs2, unsigned<4> nf, unsigned<4> index_byte_size, unsigned<3> data_byte_size, unsigned<1> ordered) [[uses_mem]];

    }
    instructions{
        // Vector Load Unit-Stride Normal & Segment (mop=0b00, lumop=0b00000) 
        VLE8__V {
            encoding: 3'b000 :: mew[0:0] :: 2'b00 :: vm[0:0] :: 5'b00000 :: rs1[4:0] :: 3'b000 :: vd[4:0] :: 7'b0000111;
            assembly: "{vname(vd)}, ({name(rs1)}), {vm}";
            behavior: if(rs1>=RFS) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                else {
                    unsigned<7> EEW = 8;
                    signed<3> EMUL_pow =  (signed<3>)(get_pow(EEW) - get_sew_pow() + get_lmul_pow());
                    if(illegal_load(vd, vm, 1, EEW, EMUL_pow)) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                    else if(vl > vstart){
                        vstart = (unsigned<XLEN>)vlseg(V, vl, vstart, vtype, vm, vd, X[rs1], 3'b000, 1);
                    }
                }
        }
