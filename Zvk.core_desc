        VAESEM__VS {
            encoding: 6'b101001 :: 1'b1 :: vs2[4:0] :: 5'b00010 :: 3'b010 :: vd[4:0] :: 7'b1110111;
            assembly: "{vname(vd)}, {vname(vs2)}";
            behavior: {
                unsigned<8> EGS = 4;
                if(!sew_32() || !zvk_valid(EGS, 128) || !zvk_valid_reg_overlap(vs2, vd, get_lmul_pow())) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                else {
                    if(vl > vstart)
                        vector_scalar_crypto(V, 6'b101001, vl/EGS, vstart/EGS, vtype, vd, vs2, 5'b00010, EGS);
                    vstart = 0;
                }
            }
        }

        VAESEM__VV {
            encoding: 6'b101000 :: 1'b1 :: vs2[4:0] :: 5'b00010 :: 3'b010 :: vd[4:0] :: 7'b1110111;
            assembly: "{vname(vd)}, {vname(vs2)}";
            behavior: {
                unsigned<8> EGS = 4;
                if(!sew_32() || !zvk_valid(EGS, 128)) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                else {
                    if(vl > vstart)
                        vector_vector_crypto(V, 6'b101000, vl/EGS, vstart/EGS, vtype, vd, vs2, 5'b00010, EGS);
                    vstart = 0;
                }
            }
        }

        VAESKF1__VI {
            encoding: 6'b100010 :: 1'b1 :: vs2[4:0] :: imm[4:0] :: 3'b010 :: vd[4:0] :: 7'b1110111;
            assembly: "{vname(vd)}, {vname(vs2)}, {imm}";
            behavior: {
                unsigned<8> EGS = 4;
                if(!sew_32() || !zvk_valid(EGS, 128) ) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                else {
                    if(vl > vstart){
                        unsigned<4> rnd = imm[3:0];
                        if (rnd > 10 || rnd == 0) 
                            rnd = (~rnd[3]) :: rnd[2:0];
                        vector_imm_crypto(V, 6'b100010, vl/EGS, vstart/EGS, vtype, vd, vs2, (unsigned<4>)(rnd-1), EGS);
                    }
                    vstart = 0;
                }
            }
        }

        VAESKF2__VI {
            encoding: 6'b101010 :: 1'b1 :: vs2[4:0] :: imm[4:0] :: 3'b010 :: vd[4:0] :: 7'b1110111;
            assembly: "{vname(vd)}, {vname(vs2)}, {imm}";
            behavior: {
                unsigned<8> EGS = 4;
                if(!sew_32() || !zvk_valid(EGS, 128) ) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                else {
                    if(vl > vstart){
                        unsigned<4> rnd = imm[3:0];
                        if (rnd > 10 || rnd == 0) 
                            rnd = (~rnd[3]) :: rnd[2:0];
                        vector_imm_crypto(V, 6'b101010, vl/EGS, vstart/EGS, vtype, vd, vs2, rnd, EGS);
                    }
                    vstart = 0;
                }
            }
        }

        VAESZ__VS {
            encoding: 6'b101001 :: 1'b1 :: vs2[4:0] :: 5'b00111 :: 3'b010 :: vd[4:0] :: 7'b1110111;
            assembly: "{vname(vd)}, {vname(vs2)}";
            behavior: {
                unsigned<8> EGS = 4;
                if(!sew_32() || !zvk_valid(EGS, 128) || !zvk_valid_reg_overlap(vs2, vd, get_lmul_pow())) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                else {
                    if(vl > vstart)
                        vector_scalar_crypto(V, 6'b101001, vl/EGS, vstart/EGS, vtype, vd, vs2, 5'b00111, EGS);
                    vstart = 0;
                }
            }
        }
    }
}

