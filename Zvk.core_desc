InstructionSet ZvkBase extends RVVBase{
    functions {
        extern void vector_vector_crypto(unsigned<VLEN> V[32], unsigned<6> funct6, unsigned<XLEN> eg_len, unsigned<XLEN> eg_start, unsigned<XLEN> vtype, unsigned<5> vd, unsigned<5> vs2, unsigned<5> vs1, unsigned<8> egs);
        extern void vector_scalar_crypto(unsigned<VLEN> V[32], unsigned<6> funct6, unsigned<XLEN> eg_len, unsigned<XLEN> eg_start, unsigned<XLEN> vtype, unsigned<5> vd, unsigned<5> vs2, unsigned<5> vs1, unsigned<8> egs);
        extern void vector_imm_crypto(unsigned<VLEN> V[32], unsigned<6> funct6, unsigned<XLEN> eg_len, unsigned<XLEN> eg_start, unsigned<XLEN> vtype, unsigned<5> vd, unsigned<5> vs2, unsigned<ELEN> imm, unsigned<8> egs);

        bool sew_32(){
            return sew() == 0b010;
        }
        bool sew_64(){
            return sew() == 0b011;
        }
        bool zvk_valid(unsigned<8> EGS, unsigned<8> EGW){
            return (vl%EGS == 0) && (vstart%EGS == 0) && (get_elem_count()*EGW/EGS >=EGW);
        }
        bool zvk_valid_reg_overlap(unsigned<5> rs, unsigned<5> rd, signed<4> EMUL_pow) {
            unsigned<5> reg_group_size = EMUL_pow > 0 ? (unsigned<5>)(5'sb1 << EMUL_pow) & ~5'b1 : 1;
            return (rs + reg_group_size <= rd) || (rd + reg_group_size <= rs);
        }
    }
}
InstructionSet Zvkg extends ZvkBase{
    instructions {
        VGHSH__VV {
            encoding: 6'b101100 :: 1'b1 :: vs2[4:0] :: vs1[4:0] :: 3'b010 :: vd[4:0] :: 7'b1110111;
            assembly: "{vname(vd)}, {vname(vs2)}, {vname(vs1)}";
            behavior: {
                if(!sew_32() || !zvk_valid(4, 128)) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                else {
                    if(vl > vstart)
                        vector_vector_crypto(V, 6'b101100, vl/4, vstart/4, vtype, vd, vs2, vs1, 4);
                    vstart = 0;
                }
            }
        }

        VGMUL__VV {
            encoding: 6'b101000 :: 1'b1 :: vs2[4:0] :: 5'b10001 :: 3'b010 :: vd[4:0] :: 7'b1110111;
            assembly: "{vname(vd)}, {vname(vs2)}";
            behavior: {
                if(!sew_32() || !zvk_valid(4, 128)) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                else {
                    if(vl > vstart)
                        vector_vector_crypto(V, 6'b101000, vl/4, vstart/4, vtype, vd, vs2, 5'b10001, 4);
                    vstart = 0;
                }
            }
        }
    }
}

InstructionSet Zvkned extends ZvkBase{
    instructions {
        VAESDF__VS {
            encoding: 6'b101001 :: 1'b1 :: vs2[4:0] :: 5'b00001 :: 3'b010 :: vd[4:0] :: 7'b1110111;
            assembly: "{vname(vd)}, {vname(vs2)}";
            behavior: {
                unsigned<8> EGS = 4;
                if(!sew_32() || !zvk_valid(EGS, 128) || !zvk_valid_reg_overlap(vs2, vd, get_lmul_pow())) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION);
                else {
                    if(vl > vstart)
