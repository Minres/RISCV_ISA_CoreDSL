            assembly: "{fname(rd)}, {fname(rs1)}, {fname(rs2)}, {fname(rs3)}, {rm}";
            behavior: {
                F[rd] = NaNBox16(fmadd_h(unbox_h(FLEN, F[rs1]), unbox_h(FLEN, F[rs2]), unbox_h(FLEN, F[rs3]), 2, get_rm(rm)));
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
        FNMSUB__H {
            encoding: rs3[4:0] :: 2'b10 :: rs2[4:0] :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1001011;
            assembly: "{fname(rd)}, {fname(rs1)}, {fname(rs2)}, {fname(rs3)}, {rm}";
            behavior: {
                F[rd] = NaNBox16(fmadd_h(unbox_h(FLEN, F[rs1]), unbox_h(FLEN, F[rs2]), unbox_h(FLEN, F[rs3]), 3, get_rm(rm)));
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
        // 23.3. Half-Precision Conversion and Move Instructions
        FCVT__W__H {
            encoding: 12'b110001000000 :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
            assembly: "{name(rd)}, {fname(rs1)}, {rm}";
            behavior: if(rd >= RFS) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION); else {
                signed<XLEN> res = (signed<XLEN>)(signed<32>)f16toi32(unbox_h(FLEN, F[rs1]), get_rm(rm));
                if (rd != 0)
                	X[rd] = (unsigned<XLEN>)res;
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
