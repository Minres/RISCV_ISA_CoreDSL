                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
        FCVT__L__H [[enable=XLEN>=64]] {
            encoding: 12'b110001000010 :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
            assembly: "{name(rd)}, {fname(rs1)}, {rm}";
            behavior: if(rd >= RFS) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION); else {
                signed<XLEN> res = (signed<XLEN>)(signed<64>)f16toi64(unbox_h(FLEN, F[rs1]), get_rm(rm));
