            }
        }
        FMAX__H {
            encoding: 7'b0010110 :: rs2[4:0] :: rs1[4:0] :: 3'b001 :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {fname(rs1)}, {fname(rs2)}";
            behavior: {
