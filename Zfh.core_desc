                    X[rd] = (unsigned<XLEN>)res; 
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
        FCVT__LU__H [[enable=XLEN>=64]] {
            encoding: 12'b110001000011 :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
            assembly: "{name(rd)}, {fname(rs1)}, {rm}";
            behavior: if(rd >= RFS) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION); else {
                unsigned<XLEN> res = f16toui64(unbox_h(FLEN, F[rs1]), get_rm(rm));
                if (rd != 0)
                    X[rd] = res; 
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
        FCVT__H__W {
            encoding: 12'b110101000000 :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
