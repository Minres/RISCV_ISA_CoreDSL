                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
        FSQRT__H {
            encoding: 12'b010111000000 :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {fname(rs1)}, {rm}";
            behavior: {
                F[rd] = NaNBox16(fsqrt_h(unbox_h(FLEN, F[rs1]), get_rm(rm)));
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
        FMADD__H {
            encoding: rs3[4:0] :: 2'b10 :: rs2[4:0] :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1000011;
            assembly: "{fname(rd)}, {fname(rs1)}, {fname(rs2)}, {fname(rs3)}, {rm}";
            behavior: {
                F[rd] = NaNBox16(fmadd_h(unbox_h(FLEN, F[rs1]), unbox_h(FLEN, F[rs2]), unbox_h(FLEN, F[rs3]), 0, get_rm(rm)));
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
