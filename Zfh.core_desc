import "RVF.core_desc"

InstructionSet Zfhmin extends RVF {
    functions {
        unsigned<FLEN> NaNBox16(unsigned<16> val){
            unsigned<FLEN> box = ~((unsigned<FLEN>)0);
            return (unsigned<FLEN>)(box :: val);
        }
        //same as in RVD
        unsigned<FLEN> NaNBox64(unsigned<64> val){
            if(FLEN == 64) return (unsigned<FLEN>)val;
            else {
                unsigned<FLEN> box = ~((unsigned<FLEN>)0);
                return (unsigned<FLEN>)(box :: val);
            }
        }
        extern unsigned<16> unbox_h(unsigned int Flen, unsigned<FLEN> val);
        extern unsigned<32> f16tof32(unsigned<16> val, unsigned<3> rm);
        extern unsigned<64> f16tof64(unsigned<16> val, unsigned<3> rm);
        extern unsigned<128> f16tof128(unsigned<16> val, unsigned<3> rm);
        extern unsigned<16> f32tof16(unsigned<32> val, unsigned<3> rm);
        extern unsigned<16> f64tof16(unsigned<64> val, unsigned<3> rm);
        extern unsigned<16> f128tof16(unsigned<128> val, unsigned<3> rm);
    }
    instructions {
        FLH {
            encoding: imm[11:0] :: rs1[4:0] :: 3'b001 :: rd[4:0] :: 7'b0000111;
            assembly: "{fname(rd)}, {imm}({name(rs1)})";
            behavior: if(rs1 >= RFS) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION); else {
                unsigned<XLEN> offs = (unsigned<XLEN>)(X[rs1] + (signed<12>)imm);
                F[rd] = NaNBox16(MEM[offs+1:offs]);
            }
        }
        FSH {
            encoding: imm[11:5] :: rs2[4:0] :: rs1[4:0] :: 3'b001 :: imm[4:0] :: 7'b0100111;
            assembly: "{fname(rs2)}, {imm}({name(rs1)})";
            behavior: if(rs1 >= RFS) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION); else {
                unsigned<XLEN> offs = (unsigned<XLEN>)(X[rs1] + (signed<12>)imm);
                MEM[offs+1:offs] = (unsigned<16>)F[rs2];
            }
        }
        FMV__X__H {
            encoding: 12'b111001000000 :: rs1[4:0] :: 3'b000 :: rd[4:0] :: 7'b1010011;
            assembly: "{name(rd)}, {fname(rs1)}";
            behavior: if(rd >= RFS) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION); else {
                if (rd != 0)
                    X[rd] = (unsigned<XLEN>)(signed<XLEN>)(signed<16>)(unsigned<16>)F[rs1];
            }
        }
        FMV__H__X {
            encoding: 12'b111101000000 :: rs1[4:0] :: 3'b000 :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {name(rs1)}";
            behavior: if(rs1 >= RFS) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION); else {
                F[rd] = NaNBox16((unsigned<16>)X[rs1]);
            }
        }
        FCVT__S__H {
            encoding: 12'b010000000010 :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {fname(rs1)}, {rm}";
            behavior: {
                F[rd] = NaNBox32(f16tof32(unbox_h(FLEN, F[rs1]), get_rm(rm)));
            }
        }
        FCVT__H__S {
            encoding: 12'b010001000000 :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {fname(rs1)}, {rm}";
            behavior: {
                F[rd] = NaNBox16(f32tof16((unsigned<32>)F[rs1], get_rm(rm)));
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
        FCVT__D__H [[enable=FLEN>=64]] {
            encoding: 12'b010000100010 :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {fname(rs1)}, {rm}";
            behavior: {
                F[rd] = NaNBox64(f16tof64(unbox_h(FLEN, F[rs1]), get_rm(rm)));
            }
        }
        FCVT__H__D [[enable=FLEN>=64]] {
            encoding: 12'b010001000001 :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {fname(rs1)}, {rm}";
            behavior: {
                F[rd] = NaNBox16(f64tof16((unsigned<64>)F[rs1], get_rm(rm)));
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
        FCVT__Q__H [[enable=FLEN>=128]] {
            encoding: 12'b010001100010 :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {fname(rs1)}, {rm}";
            behavior: {
                F[rd] = f16tof128(unbox_h(FLEN, F[rs1]), get_rm(rm));
            }
        }
        FCVT__H__Q [[enable=FLEN>=128]] {
            encoding: 12'b010001000011 :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {fname(rs1)}, {rm}";
            behavior: {
                F[rd] = NaNBox16(f128tof16((unsigned<128>)F[rs1], get_rm(rm)));
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
    }
}
