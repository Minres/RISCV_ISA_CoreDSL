                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }

        // 23.5. Half-Precision Floating-Point Classify Instruction
        FCLASS__H {
            encoding: 12'b111001000000 :: rs1[4:0] :: 3'b001 :: rd[4:0] :: 7'b1010011;
            assembly: "{name(rd)}, {fname(rs1)}";
            behavior: if(rd >= RFS) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION); else {
                unsigned<32> res = fclass_h(unbox_h(FLEN, F[rs1]));
                if (rd != 0) X[rd] = res;
            }
        }
    }
}
