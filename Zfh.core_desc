        FSGNJN__H {
            encoding: 7'b0010010 :: rs2[4:0] :: rs1[4:0] :: 3'b001 :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {fname(rs1)}, {fname(rs2)}";
            behavior:{
                F[rd] = NaNBox16(~unbox_h(FLEN, F[rs2])[15:15] :: unbox_h(FLEN, F[rs1])[14:0]);
            }
        }
        FSGNJX__H {
            encoding: 7'b0010010 :: rs2[4:0] :: rs1[4:0] :: 3'b010 :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {fname(rs1)}, {fname(rs2)}";
            behavior:{
                F[rd] = NaNBox16((unbox_h(FLEN, F[rs2]) & ((unsigned<16>)1<<15)) ^ unbox_h(FLEN, F[rs1]));
            }
        }

        // 23.4. Half-Precision Floating-Point Compare Instructions
        FEQ__H {
            encoding: 7'b1010010 :: rs2[4:0] :: rs1[4:0] :: 3'b010 :: rd[4:0] :: 7'b1010011;
            assembly: "{name(rd)}, {fname(rs1)}, {fname(rs2)}";
            behavior: if(rd >= RFS) raise(0, RV_CAUSE_ILLEGAL_INSTRUCTION); else {
                unsigned<32> res = fcmp_h(unbox_h(FLEN, F[rs1]), unbox_h(FLEN, F[rs2]), 0);
                if (rd != 0) X[rd] = res;
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
        FLT__H {
            encoding: 7'b1010010 :: rs2[4:0] :: rs1[4:0] :: 3'b001 :: rd[4:0] :: 7'b1010011;
