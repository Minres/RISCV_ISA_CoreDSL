        extern unsigned<16> i64tof16(unsigned<64> v, unsigned<3> rm);
        extern unsigned<16> ui64tof16(unsigned<64> v, unsigned<3> rm);
    }
    instructions {

        // 23.2. Half-Precision Computational Instructions
        FADD__H {
            encoding: 7'b0000010 :: rs2[4:0] :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
            assembly: "{fname(rd)}, {fname(rs1)}, {fname(rs2)}, {rm}";
            behavior: {
                F[rd] = NaNBox16(fadd_h(unbox_h(FLEN, F[rs1]), unbox_h(FLEN, F[rs2]), get_rm(rm)));
                unsigned<32> flags = fget_flags();
                FCSR = (FCSR & ~FFLAG_MASK) | (flags & FFLAG_MASK);
            }
        }
        FSUB__H {
            encoding: 7'b0000110 :: rs2[4:0] :: rs1[4:0] :: rm[2:0] :: rd[4:0] :: 7'b1010011;
