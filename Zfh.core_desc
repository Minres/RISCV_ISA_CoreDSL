        extern unsigned<16> fsel_h(unsigned<16> l, unsigned<16> r, unsigned<16> o);
        extern unsigned<16> fsqrt_h(unsigned<16> l, unsigned char m);
        extern unsigned<16> fcmp_h(unsigned<16> l, unsigned<16> r, unsigned<16> m);
        extern unsigned<16> fclass_h(unsigned<16> v);    
        extern unsigned<32> f16toi32(unsigned<16> v, unsigned<3>rm);
        extern unsigned<32> f16toui32(unsigned<16> v, unsigned<3>rm);
        extern unsigned<64> f16toi64(unsigned<16> v, unsigned<3>rm);
        extern unsigned<64> f16toui64(unsigned<16> v, unsigned<3>rm);
